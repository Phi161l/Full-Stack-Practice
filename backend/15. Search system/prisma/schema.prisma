generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  price       Decimal
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([category])
}