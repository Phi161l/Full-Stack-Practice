generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model File {
  id            Int      @id @default(autoincrement())

  filename      String
  originalName  String

  path          String
  size          Int

  mimeType      String

  createdAt     DateTime @default(now())
}