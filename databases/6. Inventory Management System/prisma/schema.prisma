generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  STAFF
}

enum MovementType {
  RECEIVE
  SALE
  DAMAGE
  RETURN
}


model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role

  movements StockMovement[]
  warehouses UserWarehouse[]

  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique

  products  Product[]

  createdAt DateTime @default(now())
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String

  movements StockMovement[]
  users UserWarehouse[]

  createdAt DateTime @default(now())
}

model UserWarehouse {
  id           String   @id @default(uuid())

  userId       String
  warehouseId  String

  user         User      @relation(fields: [userId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt    DateTime  @default(now())

  @@unique([userId, warehouseId])
}


model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  description String?

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  movements   StockMovement[]

  createdAt   DateTime @default(now())
}

model StockMovement {
  id         String   @id @default(uuid())

  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])


  type       MovementType
  quantity   Int

  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([warehouseId])
}
